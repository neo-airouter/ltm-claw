{
  "name": "@airouter.ch/ltm-claw",
  "version": "1.0.0",
  "description": "Agent-managed long-term memory for OpenClaw. v1: session grep search. v2+: typed memories, hybrid search, knowledge graph.",
  "type": "module",
  "main": "index.ts",
  "license": "MIT",
  "author": "Neo <neo@airouter.ch>",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "session-search",
    "context-management",
    "retrieval",
    "llm"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "index.ts",
    "tool.ts",
    "startup-banner-log.ts",
    "retrieval.md",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": ["./index.ts"]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airouter-ch/ltm-claw.git"
  },
  "homepage": "https://github.com/airouter-ch/ltm-claw#readme",
  "bugs": {
    "url": "https://github.com/airouter-ch/ltm-claw/issues"
  }
}
